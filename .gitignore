# 系统
.DS_Store
Thumbs.db

# 打包产物与虚拟环境
build/
dist/
release/
.venv-build/
*.venv/
.venv*/
__pycache__/

# 编辑器
.vscode/
.idea/
*.swp

# 本地服务配置（含 API Key，切勿提交）
.paper-helper/
.yanzhan/
tools/builtin_api_key.txt

# 云端多用户数据（用户库与每用户数据，切勿提交）
data/

# Obsidian 工作区缓存（保留 .obsidian 配置可按需取消忽略）
.obsidian/workspace*.json
.obsidian/cache

# Reasonix 工具缓存
.reasonix/

# 原始资料（用户上传的 PDF/docx，不提交）
raw/sources/*
!raw/sources/.gitkeep

# 运行时知识库（Ingest 自动生成，不提交）
/wiki/

# 主题下的运行时数据
topics/*/wiki/
topics/*/docs/
topics/*/raw/sources/*
!topics/*/raw/sources/.gitkeep
topics/topic-*/
topics/*/progress.json

# CodeGraph 工具缓存
.codegraph/
